{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "redirects": [{ "source": "/", "destination": "/index.html", "permanent": false }],
  "rewrites": [
    { "source": "/health", "destination": "/api" },
    { "source": "/v1/(.*)", "destination": "/api" }
  ]
}
