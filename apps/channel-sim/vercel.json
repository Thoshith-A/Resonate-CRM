{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "echo 'channel-sim: no build step — @vercel/node compiles api/index.ts'",
  "outputDirectory": "public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }]
}
